<section class="comment-section" style="margin-top:24px;">
    <div class="comment-section-header">
        <h3>评论区（<span id="commentCount">{{ commentCount }}</span> 条）</h3>
        {% if isUserLoggedIn() %}
            <button class="btn btn-sm" onclick="openCommentModal()">发表评论</button>
        {% else %}
            <a href="/login?redirect={{ request_uri|url_encode }}" class="btn btn-sm">登录后评论</a>
        {% endif %}
    </div>
    <div class="comment-list" id="commentList">
        {% if comments is not empty %}
            {% for comment in comments %}
                <div class="comment-item" id="comment-{{ comment.id }}" data-comment-content="{{ comment.content|e('html_attr') }}">
                    <div class="comment-author">
                        <span class="comment-author-info">
                            {% if comment.avatar and comment.avatar is not empty %}
                                <img src="/{{ comment.avatar }}" class="comment-author-avatar" alt="">
                            {% else %}
                                <span class="comment-author-avatar fallback">{{ comment.username|slice(0,1) }}</span>
                            {% endif %}
                            <strong><a href="/profile?user_id={{ comment.user_id }}" class="comment-user-link">{{ comment.username }}</a></strong>
                            {% if comment.parent_id and comment.parent_username %}
                                <span class="comment-reply-to">回复 <a href="/profile?user_id={{ comment.parent_user_id|default(0) }}" class="comment-user-link">{{ comment.parent_username }}</a></span>
                            {% endif %}
                        </span>
                        <span class="comment-meta-right">
                            <span class="comment-time">{{ comment.created_at|date('Y-m-d H:i') }}</span>
                            {% if isUserLoggedIn() %}
                                <button class="comment-reply-btn" data-comment-id="{{ comment.id }}" data-comment-username="{{ comment.username }}">回复</button>
                            {% endif %}
                            {% if isUserLoggedIn() and current_user_id == comment.user_id %}
                                <button class="comment-reply-btn comment-edit-btn" data-comment-id="{{ comment.id }}">编辑</button>
                            {% endif %}
                            {% if isAdmin() %}
                                <button class="comment-delete-btn" data-comment-id="{{ comment.id }}" title="删除评论">删除</button>
                            {% endif %}
                        </span>
                    </div>
                    <div class="comment-body markdown-body">
                        {% if comment.parent_id and comment.parent_username %}
                            <div class="comment-reply-context">
                                <div class="comment-reply-header">回复 <span class="comment-user-link">@{{ comment.parent_username }}</span></div>
                                <a href="{{ comment.parent_quote_url|default('#') }}" class="comment-reply-quote">{{ comment.parent_content|default('')|striptags|slice(0,240) }}</a>
                                <div class="comment-reply-divider"></div>
                            </div>
                        {% endif %}
                        <div class="comment-main-content">{{ comment.content|raw }}</div>
                    </div>
                </div>
            {% endfor %}
        {% else %}
            <div class="comment-empty" id="commentEmpty">暂无评论，来发表第一条评论吧</div>
        {% endif %}
    </div>
    {% if commentPagination.totalPages > 1 %}
        <div class="pagination" style="margin-top:18px;">
            {% if commentPagination.page > 1 %}<a href="/discussion.php?id={{ discussion.id }}&comment_page=1#commentList">第一页</a>{% endif %}
            {% if commentPagination.hasPrev %}<a href="/discussion.php?id={{ discussion.id }}&comment_page={{ commentPagination.page - 1 }}#commentList">上一页</a>{% endif %}
            <span class="current">{{ commentPagination.page }} / {{ commentPagination.totalPages }}</span>
            {% if commentPagination.hasNext %}<a href="/discussion.php?id={{ discussion.id }}&comment_page={{ commentPagination.page + 1 }}#commentList">下一页</a>{% endif %}
            {% if commentPagination.page < commentPagination.totalPages %}<a href="/discussion.php?id={{ discussion.id }}&comment_page={{ commentPagination.totalPages }}#commentList">最后一页</a>{% endif %}
        </div>
    {% endif %}
</section>
