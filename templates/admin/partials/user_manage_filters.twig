<div class="card" style="margin-bottom: 20px;">
    <div class="card-body" style="padding: 16px;">
        <form method="get" style="display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end;">
            <div>
                <label class="form-label" style="margin-bottom: 4px; font-size: 0.82rem;">角色筛选</label>
                <select name="role_filter" class="form-input" style="width: auto; min-width: 120px;">
                    <option value="" {{ roleFilter == '' ? 'selected' : '' }}>全部角色</option>
                    <option value="user" {{ roleFilter == 'user' ? 'selected' : '' }}>普通用户</option>
                    <option value="admin" {{ roleFilter == 'admin' ? 'selected' : '' }}>管理员</option>
                    <option value="sub" {{ roleFilter == 'sub' ? 'selected' : '' }}>子管理员</option>
                    <option value="super" {{ roleFilter == 'super' ? 'selected' : '' }}>超级管理员</option>
                </select>
            </div>
            <div>
                <label class="form-label" style="margin-bottom: 4px; font-size: 0.82rem;">搜索方式</label>
                <select name="search_type" class="form-input" style="width: auto; min-width: 140px;">
                    <option value="username" {{ searchType == 'username' or searchType == '' ? 'selected' : '' }}>用户名（模糊）</option>
                    <option value="username_exact" {{ searchType == 'username_exact' ? 'selected' : '' }}>用户名（精确）</option>
                    <option value="id" {{ searchType == 'id' ? 'selected' : '' }}>用户 ID</option>
                </select>
            </div>
            <div style="flex: 1; min-width: 200px;">
                <label class="form-label" style="margin-bottom: 4px; font-size: 0.82rem;">关键词</label>
                <input type="text" name="keyword" class="form-input" placeholder="输入搜索关键词" value="{{ searchKeyword }}">
            </div>
            <div>
                <button type="submit" class="btn" style="margin-bottom: 0;">搜索</button>
                {% if searchKeyword or roleFilter %}
                    <a href="user_manage.php" class="btn btn-secondary" style="margin-bottom: 0;">清除</a>
                {% endif %}
            </div>
        </form>
    </div>
</div>
