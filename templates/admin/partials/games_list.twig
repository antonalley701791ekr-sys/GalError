{% include 'admin/partials/page_header_actions.twig' with {
    title: '游戏管理',
    actions: [
        {'href': 'games.php?action=add', 'label': '添加游戏', 'class': 'btn-success'}
    ]
} %}

{% include 'admin/partials/list_filters.twig' with {
    filters: [
        {'href': 'games.php', 'label': '全部', 'active': not status},
        {'href': 'games.php?status=pending', 'label': '待审核', 'active': status == 'pending', 'badge': gameStats.pending},
        {'href': 'games.php?status=approved', 'label': '已通过', 'active': status == 'approved'},
        {'href': 'games.php?status=rejected', 'label': '已拒绝', 'active': status == 'rejected'}
    ]
} %}

<div class="admin-stats-grid">
    <div class="card stat-card"><div class="card-body"><h3 class="stat-number stat-number--cyan">{{ gameStats.total }}</h3><p class="stat-label">总数</p></div></div>
    <div class="card stat-card"><div class="card-body"><h3 class="stat-number stat-number--yellow">{{ gameStats.pending }}</h3><p class="stat-label">待审核</p></div></div>
    <div class="card stat-card"><div class="card-body"><h3 class="stat-number stat-number--green">{{ gameStats.approved }}</h3><p class="stat-label">已通过</p></div></div>
    <div class="card stat-card"><div class="card-body"><h3 class="stat-number stat-number--red">{{ gameStats.rejected }}</h3><p class="stat-label">已拒绝</p></div></div>
    <div class="card stat-card"><div class="card-body"><h3 class="stat-number stat-number--yellow">{{ pendingGameRevisionCount }}</h3><p class="stat-label">待审修改</p></div></div>
</div>

{% include 'admin/partials/games_pending_revisions.twig' %}

<div class="card">
    <div class="card-header">游戏列表<span class="text-muted" style="float:right;font-weight:normal;">共 {{ total }} 条记录</span></div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table">
                <thead><tr><th>封面</th><th>游戏信息</th><th>VNDB ID</th><th>状态</th><th>提交时间</th><th>操作</th></tr></thead>
                <tbody>
                    {% if games is empty %}
                        <tr><td colspan="6" class="text-center text-muted" style="padding:40px;">暂无数据</td></tr>
                    {% endif %}
                    {% for game in games %}
                        <tr>
                            <td>
                                {% if game.cover_url %}
                                    <img src="{{ game.cover_url }}" alt="{{ game.title }}" style="width:50px;height:70px;object-fit:cover;border-radius:4px;">
                                {% else %}
                                    <div style="width:50px;height:70px;background:var(--glass-bg);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:10px;" class="text-muted">无</div>
                                {% endif %}
                            </td>
                            <td>
                                <strong>{{ game.title }}</strong>
                                {% if game.title_jp %}<br><small class="text-muted">{{ game.title_jp }}</small>{% endif %}
                                {% if game.aliases %}<br><small class="text-muted">{{ game.aliases }}</small>{% endif %}
                                {% if game.developer %}<br><small class="text-muted">{{ game.developer }}</small>{% endif %}
                            </td>
                            <td>{{ game.vndb_id|default('-') }}</td>
                            <td><span class="status status-{{ game.status }}">{{ statusText[game.status] ?? game.status }}</span></td>
                            <td>{{ game.created_at|date('Y-m-d H:i') }}</td>
                            <td>
                                <div class="action-btns">
                                    <a href="/admin/games.php?action=view&id={{ game.id }}" class="btn btn-sm">查看</a>
                                    <form method="post" action="/admin/games.php?id={{ game.id }}" style="display:inline;">
                                        {{ csrf_input('admin_form')|raw }}
                                        <input type="hidden" name="action" value="delete">
                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('确认删除该游戏？');">删除</button>
                                    </form>
                                    {% include 'admin/partials/review_actions.twig' with {
                                        canApprove: game.status == 'pending',
                                        approveAction: '/admin/games.php?id=' ~ game.id,
                                        approveActionName: 'approve',
                                        approveId: game.id,
                                        approveLabel: '通过',
                                        approveConfirm: '确认通过该游戏？',
                                        canReject: game.status == 'pending',
                                        rejectAction: '/admin/games.php?action=reject&id=' ~ game.id,
                                        rejectId: game.id,
                                        rejectReason: '未通过审核',
                                        rejectLabel: '驳回',
                                        rejectConfirm: '确认驳回该游戏？'
                                    } %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
