<div class="card settings-section" id="smtpSection"><div class="card-header">SMTP 服务器配置</div><div class="card-body"><div class="form-group"><label class="form-label">SMTP 服务器地址</label><input type="text" name="smtp_host" class="form-input" value="{{ settings.smtp_host|default('') }}" placeholder="例如：smtp.qq.com"></div><div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;"><div class="form-group"><label class="form-label">端口</label><input type="number" name="smtp_port" class="form-input" value="{{ settings.smtp_port|default('465') }}" placeholder="465"><p class="form-hint">SSL 通常用 465，TLS 通常用 587</p></div><div class="form-group"><label class="form-label">加密方式</label><select name="smtp_secure" class="form-input"><option value="ssl" {{ (settings.smtp_secure|default('ssl')) == 'ssl' ? 'selected' : '' }}>SSL</option><option value="tls" {{ (settings.smtp_secure|default('ssl')) == 'tls' ? 'selected' : '' }}>TLS</option><option value="" {{ settings.smtp_secure|default('') == '' ? 'selected' : '' }}>无加密</option></select></div></div><div class="form-group"><label class="form-label">用户名</label><input type="text" name="smtp_user" class="form-input" value="{{ settings.smtp_user|default('') }}" placeholder="SMTP 登录账号（通常为邮箱地址）"></div><div class="form-group"><label class="form-label">密码 / 授权码</label><input type="password" name="smtp_pass" class="form-input" value="" placeholder="{{ settings.smtp_pass is defined and settings.smtp_pass ? '已设置（留空保留原密码）' : '请输入密码或授权码' }}">{% if settings.smtp_pass is defined and settings.smtp_pass %}<p class="form-hint">密码已保存，留空提交将保留当前密码</p>{% endif %}</div></div></div>
