<div class="card settings-section"><div class="card-header">发件人信息</div><div class="card-body"><div class="form-group"><label class="form-label">发件人邮箱</label><input type="email" name="mail_from" class="form-input" value="{{ settings.mail_from|default('') }}" placeholder="例如：noreply@galerror.top"><p class="form-hint">使用 Resend 时，域名需与 Resend 中验证的域名一致</p></div><div class="form-group"><label class="form-label">发件人名称</label><input type="text" name="mail_from_name" class="form-input" value="{{ settings.mail_from_name|default('') }}" placeholder="例如：{{ _site_name }}"></div></div></div>
