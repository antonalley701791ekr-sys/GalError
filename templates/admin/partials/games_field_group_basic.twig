<div class="card" style="margin-bottom:16px;">
    <div class="card-header">基础信息</div>
    <div class="card-body">
        <div class="form-group">
            <label class="form-label">VNDB ID（可选）</label>
            <input type="text" name="vndb_id" class="form-input" value="{{ game.vndb_id|default('') }}">
        </div>
        <div class="form-group">
            <label class="form-label">游戏标题 *</label>
            <input type="text" name="title" class="form-input" required value="{{ game.title|default('') }}">
        </div>
        <div class="form-group">
            <label class="form-label">日文名</label>
            <input type="text" name="title_jp" class="form-input" value="{{ game.title_jp|default('') }}">
        </div>
        <div class="form-group">
            <label class="form-label">罗马音</label>
            <input type="text" name="romaji" class="form-input" value="{{ game.romaji|default('') }}">
        </div>
    </div>
</div>
