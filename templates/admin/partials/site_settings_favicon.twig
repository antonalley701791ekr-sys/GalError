<div class="card settings-section"><div class="card-header">Favicon</div><div class="card-body">{% if settings.favicon is defined and settings.favicon %}<div class="image-preview" style="margin-bottom: 10px;"><img src="/{{ settings.favicon }}" alt="当前 Favicon" style="max-width: 48px; max-height: 48px;"></div>{% endif %}<input type="file" name="favicon" class="form-input" accept="image/*" style="max-width: 400px;"><p class="form-hint">支持 ICO/PNG/SVG 格式，单张图片大小不超过 4MB。</p></div></div>
