<div class="card" style="margin-bottom:16px;">
    <div class="card-header">补充信息</div>
    <div class="card-body">
        <div class="form-group">
            <label class="form-label">别名</label>
            <input type="text" name="aliases" class="form-input" value="{{ game.aliases|default('') }}">
        </div>
        <div class="form-group">
            <label class="form-label">开发商</label>
            <input type="text" name="developer" class="form-input" value="{{ game.developer|default('') }}">
        </div>
        <div class="form-group">
            <label class="form-label">发售日</label>
            <input type="date" name="release_date" class="form-input" value="{{ game.release_date|default('') }}">
        </div>
        <div class="form-group">
            <label class="form-label">平台</label>
            <input type="text" name="platforms" class="form-input" value="{{ game.platforms|default('') }}">
        </div>
    </div>
</div>
