<div class="card">
    <div class="card-header">编辑报错</div>
    <div class="card-body">
        <form method="post" action="?action=save&id={{ viewError.id }}">
            {{ csrf_input('admin_form')|raw }}
            <div class="form-group">
                <label class="form-label">标题</label>
                <input type="text" name="title" class="form-input" value="{{ viewError.title|default('') }}" required>
            </div>
            <div class="form-group">
                <label class="form-label">问题描述</label>
                <textarea name="phenomenon" class="form-textarea" rows="5" required>{{ viewError.phenomenon|default('') }}</textarea>
            </div>
            <div class="form-group">
                <label class="form-label">系统信息</label>
                <input type="text" name="system_info" class="form-input" value="{{ viewError.system_info|default('') }}">
            </div>
            <div class="btn-group">
                <button type="submit" class="btn">保存</button>
                <a href="?action=view&id={{ viewError.id }}" class="btn btn-secondary">取消</a>
            </div>
        </form>
    </div>
</div>
