{% include 'admin/partials/games_header.twig' %}
{% include 'admin/partials/games_message.twig' %}

{% if action == 'view' and viewGame %}
    {% include 'admin/partials/games_detail.twig' with { game: viewGame } %}
{% elseif action == 'add' or action == 'edit' %}
    {% include 'admin/partials/games_edit.twig' with { game: editGame, formTitle: action == 'edit' ? '编辑游戏' : '添加游戏', submitLabel: action == 'edit' ? '更新游戏' : '添加游戏' } %}
{% else %}
    {% include 'admin/partials/games_list.twig' %}
{% endif %}
