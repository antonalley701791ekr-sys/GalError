{% include 'admin/partials/errors_revision_images_diff.twig' with { title: '解决方案截图变化', addedImages: rev.added_solution_screenshots|default([]), removedImages: rev.removed_solution_screenshots|default([]), uploadUrl: constant('UPLOAD_URL') } %}
