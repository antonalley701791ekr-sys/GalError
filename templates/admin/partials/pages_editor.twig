<div class="card">
    <div class="card-header">
        编辑「{{ editPage.title }}"
        <span style="float:right;color:var(--text-muted);font-weight:normal;font-size:0.85rem;">{{ (pageMeta[editPage.slug]|default({'desc': ''})).desc }}</span>
    </div>
    <div class="card-body">
        <form method="post">
            {{ csrf_input('admin_form')|raw }}
            <div class="form-group">
                <label class="form-label">页面内容</label>
                <div class="md-editor-wrap">
                    <div class="md-mode-tabs">
                        <button type="button" class="md-mode-tab active" data-mode="edit">编写</button>
                        <button type="button" class="md-mode-tab" data-mode="preview">预览</button>
                        <button type="button" class="md-mode-tab" data-mode="split">分栏</button>
                    </div>
                    <div class="md-editor-toolbar">
                        <button type="button" data-action="h1">H1</button>
                        <button type="button" data-action="h2">H2</button>
                        <button type="button" data-action="h3">H3</button>
                        <span class="md-toolbar-separator"></span>
                        <button type="button" data-action="bold"><b>B</b></button>
                        <button type="button" data-action="italic"><i>I</i></button>
                        <button type="button" data-action="strikethrough"><s>S</s></button>
                        <span class="md-toolbar-separator"></span>
                        <button type="button" data-action="link">链接</button>
                        <button type="button" data-action="mention">@用户</button>
                        <button type="button" data-action="image">插入图片</button>
                        <span class="md-toolbar-separator"></span>
                        <button type="button" data-action="code">`</button>
                        <button type="button" data-action="codeblock">&lt;/&gt;</button>
                        <span class="md-toolbar-separator"></span>
                        <button type="button" data-action="ul">• 列表</button>
                        <button type="button" data-action="ol">1. 列表</button>
                        <button type="button" data-action="quote">&gt; 引用</button>
                        <span class="md-toolbar-separator"></span>
                        <button type="button" data-action="hr">---</button>
                        <button type="button" data-action="table">表格</button>
                        <button type="button" data-action="tsvtable">文本转表</button>
                    </div>
                    <div class="md-editor-body mode-edit">
                        <textarea id="md-editor" name="content" class="md-editor-textarea" style="min-height:400px;">{{ editPage.content|e }}</textarea>
                        <div id="md-preview" class="md-editor-preview-pane"></div>
                    </div>
                    <div class="md-editor-hint">支持 Markdown 语法 | <kbd>Tab</kbd> 缩进 | <kbd>Shift+Tab</kbd> 取消缩进</div>
                </div>
                <input type="file" id="md-image-uploader" accept="image/*" style="display:none;">
            </div>
            <div class="btn-group">
                <button type="submit" class="btn">保存</button>
                <a href="pages.php" class="btn btn-secondary">取消</a>
            </div>
        </form>
    </div>
</div>

<script src="/assets/js/marked.min.js"></script>
<script src="/assets/js/markdown-editor.js"></script>
<script src="/assets/js/pages-editor.js?v={{ _assets_ver }}"></script>
