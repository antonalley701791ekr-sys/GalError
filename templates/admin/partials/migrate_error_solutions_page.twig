<div class="admin-page-header"><h1>解决方案迁移</h1></div>
{% if message %}<div class="admin-alert-{{ message_type }}">{{ message }}</div>{% endif %}
<div class="card"><div class="card-header">迁移说明</div><div class="card-body">
    <p class="text-muted">将旧字段中的历史方案迁移到 `error_solutions`，并把历史方案截图一并迁移到方案表中。</p>
    <form method="post" onsubmit="return confirm('确定开始迁移历史解决方案吗？建议先备份数据库。');">
        {{ csrf_input('admin_form')|raw }}
        <input type="hidden" name="action" value="migrate">
        <button type="submit" class="btn btn-warning">开始迁移历史方案</button>
    </form>
</div></div>
{% if previewRows is defined and previewRows is not empty %}
<div class="card" style="margin-top:20px;"><div class="card-header">迁移预览</div><div class="card-body">
    <div class="table-responsive"><table class="table"><thead><tr><th>ID</th><th>标题</th><th>现有方案条数</th><th>方案预览</th></tr></thead><tbody>
    {% for row in previewRows %}
        <tr><td>{{ row.id }}</td><td>{{ row.title }}</td><td>{{ row.solution_count }}</td><td>{{ row.solution_preview }}</td></tr>
    {% endfor %}
    </tbody></table></div>
</div></div>
{% endif %}
