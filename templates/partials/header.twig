                    <a href="/articles" class="nav-dropdown-menu-item">文章列表</a>
                    <a href="{{ submit_article_url }}" class="nav-dropdown-menu-item">提交文章</a>
                </div></div>
            </div>
            <div class="nav-dropdown-wrapper">
                <span class="nav-dropdown-trigger">游戏</span>
