<script>
window.__CSRF_TOKEN__ = {{ csrf_token_json|raw }};
window.__API_CODE_MESSAGE_MAP__ = {{ api_code_message_map_json|raw }};

window.getApiMessage = function(resp, fallback) {
    var defaultMsg = fallback || '操作失败，请稍后重试';
    if (!resp || typeof resp !== 'object') return defaultMsg;
    var code = resp.code || '';
    if (code && window.__API_CODE_MESSAGE_MAP__ && window.__API_CODE_MESSAGE_MAP__[code]) {
        return window.__API_CODE_MESSAGE_MAP__[code];
    }
    if (resp.message && typeof resp.message === 'string') {
        return resp.message;
    }
    return defaultMsg;
};

window.handleApiError = function(resp, fallback, options) {
    var msg = window.getApiMessage(resp, fallback);
    var code = resp && typeof resp === 'object' ? (resp.code || '') : '';
    var opts = options || {};
    function hasDirtyInput() {
        try {
            var selectors = 'input:not([type="hidden"]):not([type="checkbox"]):not([type="radio"]), textarea, select';
            var nodes = document.querySelectorAll(selectors);
            for (var i = 0; i < nodes.length; i++) {
                var el = nodes[i];
                if (!el || el.disabled || el.readOnly) continue;
                if (el.tagName === 'SELECT') { if (el.selectedIndex > 0) return true; continue; }
                var val = (el.value || '').trim();
                if (val !== '') return true;
            }
        } catch (e) {}
        return false;
    }
    if (code === 'csrf_failed') {
        var shouldReload = typeof opts.autoReloadOnCsrfFailed === 'boolean' ? opts.autoReloadOnCsrfFailed : true;
        var preventWhenDirty = typeof opts.preventReloadWhenDirty === 'boolean' ? opts.preventReloadWhenDirty : true;
        if (shouldReload && (!preventWhenDirty || !hasDirtyInput())) {
            var delayMs = typeof opts.reloadDelayMs === 'number' ? opts.reloadDelayMs : 1200;
            setTimeout(function() { try { window.location.reload(); } catch (e) {} }, Math.max(0, delayMs));
        }
    }
    return msg;
};
</script>
<header class="header">
    <div class="container">
        <a href="/" class="logo">
            {% if site_logo %}
                <img src="/{{ site_logo }}" alt="" class="logo-img">
            {% endif %}
