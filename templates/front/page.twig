<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page.title }} - {{ site_name }}</title>
    <link rel="stylesheet" href="/assets/css/style.css?v={{ _assets_ver }}">
    <link rel="stylesheet" href="/assets/css/user.css?v={{ _assets_ver }}">
    <link rel="stylesheet" href="/assets/css/markdown-editor.css">
    {{ site_head_html|raw }}
</head>
<body class="has-fixed-nav">
    {{ header_html|raw }}

    <main class="main">
        <div class="container" style="max-width: 900px;">
            <div class="doc-detail-breadcrumb">
                <a href="/">首页</a> &gt; <span>{{ page.title }}</span>
            </div>

            <div class="card">
                <div class="card-body">
                    <div class="doc-detail-header">
                        <h1 class="doc-detail-title">{{ page.title }}</h1>
                    </div>
                    <div class="doc-detail-content markdown-body">
                        {% if page.content_html %}
                            {{ page.content_html|raw }}
                        {% else %}
                            <p class="text-muted" style="text-align:center;padding:40px 0;">暂无内容</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </main>

    {{ footer_html|raw }}
</body>
</html>
