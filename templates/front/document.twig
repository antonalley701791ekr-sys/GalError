<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ doc.title }} - {{ site_name }}</title>
    <link rel="stylesheet" href="/assets/css/style.css?v={{ _assets_ver }}">
    <link rel="stylesheet" href="/assets/css/user.css?v={{ _assets_ver }}">
    <link rel="stylesheet" href="/assets/css/markdown-editor.css">
    {{ site_head_html|raw }}
</head>
<body class="has-fixed-nav">
    {{ header_html|raw }}

    <main class="main">
        <div class="container" style="max-width: 900px;">
            <div class="doc-detail-breadcrumb">
                <a href="/">首页</a> &gt; <span>{{ doc.title_short }}</span>
            </div>

            <div class="card">
                <div class="card-body">
                    <div class="doc-detail-header">
                        <h1 class="doc-detail-title">{{ doc.title }}</h1>
                        {% if doc.description %}<p class="doc-detail-desc">{{ doc.description }}</p>{% endif %}
                    </div>
                    <div class="doc-detail-content markdown-body">{{ doc.content_html|raw }}</div>
                </div>
            </div>
        </div>
    </main>

    {{ footer_html|raw }}
</body>
</html>
