<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if edit_mode %}修改解决方案{% else %}补充新解决方案{% endif %} - {{ _site_name }}</title>
    <link rel="stylesheet" href="/assets/css/style.css?v={{ _assets_ver }}">
    <link rel="stylesheet" href="/assets/css/user.css?v={{ _assets_ver }}">
    {{ site_head_html|raw }}
</head>
<body class="has-fixed-nav">
    {{ header_html|raw }}
    {{ announcement_html|raw }}
    <main class="main">
        <div class="container">
            <div class="card">
                <div class="card-header">{% if edit_mode %}修改解决方案{% else %}补充新解决方案{% endif %}</div>
                <div class="card-body">
                    {% if message %}<div class="alert-{{ message_type }}">{{ message }}</div>{% endif %}
                    <div class="info-block" style="margin-bottom:16px;">
                        <strong>{{ error.title }}</strong><br>
                        游戏：{{ error.game_title }}<br>
                        分类：{{ error.category_name }}<br>
                        <span class="text-muted">{% if edit_mode %}当前进入的是“修改方案”模式。{% else %}当前进入的是“补充新方案”模式。{% endif %}上传图片支持 JPG、PNG、GIF、WEBP 格式，单个文件最大 4MB。</span>
                    </div>
                    <form method="post" enctype="multipart/form-data" onsubmit="return confirm('确认提交解决方案吗？');">
                        {{ csrf_html|raw }}
                        <input type="hidden" name="error_id" value="{{ error.id }}">
                        <div class="form-group">
                            <label class="form-label">解决方案 *</label>
                            <textarea name="solution" id="solution_textarea" class="form-textarea" rows="8" required placeholder="详细描述解决步骤和方法">{% if edit_mode %}{{ error.solution_text }}{% endif %}</textarea>
                            <small class="text-muted">{% if edit_mode %}当前为编辑模式，会回填该方案内容。{% else %}当前为新增模式，不会回填任何已有内容。{% endif %}</small>
                        </div>
                        <div class="form-group">
                            <label class="form-label">解决方案截图（可选，最多5张）</label>
                            {% if edit_mode and error.solution_screenshots %}
                            <div class="screenshot-list" style="margin-bottom:10px;">
                                {% for screenshot in error.solution_screenshots %}
                                <label style="display:inline-flex;flex-direction:column;gap:6px;align-items:flex-start;cursor:pointer;">
                                    <img src="{{ upload_url }}{{ screenshot }}" alt="解决方案截图" class="screenshot-thumb js-image-viewer-trigger" data-viewer-src="{{ upload_url }}{{ screenshot }}" data-viewer-alt="解决方案截图">
                                    <span style="display:inline-flex;align-items:center;gap:6px;font-size:.9rem;">
                                        <input type="checkbox" name="keep_solution_screenshots[]" value="{{ screenshot }}" checked>
                                        <span>保留本图</span>
                                    </span>
                                </label>
                                {% endfor %}
                            </div>
                            {% endif %}
                            <input type="file" name="solution_screenshots[]" class="form-input" accept="image/*" multiple>
                            <small class="text-muted">{% if edit_mode %}编辑模式会自动显示当前方案截图；新增图片会与已保留的图片合并。{% else %}新增模式不会回填任何图片，请直接上传要添加的截图。{% endif %}支持 JPG、PNG、GIF 格式，单个文件最大 4MB。</small>
                        </div>
                        <div class="form-group">
                            <input type="hidden" name="submit_as_new" value="1">
                        </div>
                        <div class="form-group">
                            <div class="btn-group">
                                <button type="submit" class="btn">{% if edit_mode %}保存修改{% else %}提交新解决方案{% endif %}</button>
                                <a href="/error_detail.php?id={{ error.id }}" class="btn btn-secondary">返回详情</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
    {{ footer_html|raw }}
    {{ page_scripts_html|raw }}
</body>
</html>
