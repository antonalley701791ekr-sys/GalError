<article class="card article-detail-card"><div class="card-body" style="padding:28px;"><h1 class="article-detail-title">{{ article.title }}</h1><div class="article-detail-meta"><span class="article-author">{% if article.avatar and article.avatar is not empty %}<img src="/{{ article.avatar }}" class="article-author-avatar" alt="">{% else %}<span class="article-author-avatar fallback">{{ article.username|slice(0,1) }}</span>{% endif %}<a href="/profile?user_id={{ article.user_id }}" class="detail-author-link">{{ article.username }}</a></span><span>{{ article.created_at|date('Y-m-d H:i') }}</span><span class="view-count-detail" title="浏览量">登录浏览：<span id="view-count-user">{{ viewCounts.user_views }}</span> | 访客浏览：<span id="view-count-guest">{{ viewCounts.guest_views }}</span></span>{% if article.status != 'approved' %}<span class="status status-{{ article.status }}">{{ article.status == 'pending' ? '待审核' : '已驳回' }}</span>{% endif %}</div>{% if tags is not empty %}<div class="article-detail-tags">{% for tag in tags %}<a href="/search?type=article&q={{ tag|trim|url_encode }}" class="article-tag">{{ tag|trim }}</a>{% endfor %}</div>{% endif %}<div class="article-detail-content markdown-body">{{ article.content_html|raw }}</div><div class="article-detail-actions">{% if is_logged_in and current_user_id == article.user_id %}{% if article.status == 'pending' or article.status == 'rejected' %}<a href="/submit_article?edit={{ article.id }}" class="btn btn-secondary btn-sm">编辑文章</a>{% elseif article.status == 'approved' and not article.has_pending_revision %}<a href="/submit_article?edit={{ article.id }}" class="btn btn-secondary btn-sm">编辑文章</a>{% elseif article.status == 'approved' and article.has_pending_revision %}<span class="btn btn-secondary btn-sm" style="opacity:0.5;cursor:not-allowed;">修改审核中</span>{% endif %}{% endif %}<a href="/articles" class="btn btn-secondary btn-sm">返回列表</a></div></div></article>
