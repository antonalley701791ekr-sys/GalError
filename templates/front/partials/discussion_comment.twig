{#
  discussion_comment.twig —— 单条讨论评论
  输入（由 discussion_comments 以 with 显式传入）：
    comment         [必填] 评论对象：id/content/content_html/avatar/username/user_id/created_at/
                          parent_id/parent_username/parent_user_id/parent_quote_url/parent_content
    current_user_id [必填] 当前用户 ID（== comment.user_id 时显示“编辑”）
    is_admin        [必填] 管理员显示“删除”
    _is_login       [必填] 登录后显示“回复/编辑”
  说明：删除按钮调用 window.galDeleteComment（与文章页的 deleteComment 不同名，见 docs/评论系统梳理.md）。
#}
<div class="comment-item" id="comment-{{ comment.id }}" data-comment-content="{{ comment.content|e('html_attr') }}">
    <div class="comment-author">
        <span class="comment-author-info">
            {% if comment.avatar and comment.avatar is not empty %}
                <img src="/{{ comment.avatar }}" class="comment-author-avatar" alt="">
            {% else %}
                <span class="comment-author-avatar fallback">{{ comment.username|slice(0, 1) }}</span>
            {% endif %}
            <strong><a href="/profile?user_id={{ comment.user_id }}" class="comment-user-link">{{ comment.username }}</a></strong>
            {% if comment.parent_id and comment.parent_username %}
                <span class="comment-reply-to">回复 <a href="/profile?user_id={{ comment.parent_user_id|default(0) }}" class="comment-user-link">{{ comment.parent_username }}</a></span>
            {% endif %}
        </span>
        <span class="comment-meta-right">
            <span class="comment-time">{{ comment.created_at|date('Y-m-d H:i') }}</span>
            {% if _is_login %}
                <button type="button" class="comment-reply-btn" data-comment-id="{{ comment.id }}" data-comment-username="{{ comment.username }}" onclick="if(window.replyToComment){window.replyToComment({{ comment.id }}, '{{ comment.username|e('js') }}');}else if(window.GalCommentInteractions&&window.GalCommentInteractions.handleReply){window.GalCommentInteractions.handleReply({{ comment.id }}, '{{ comment.username|e('js') }}');}">回复</button>
            {% endif %}
            {% if _is_login and comment.user_id == current_user_id %}
                <button type="button" class="comment-reply-btn comment-edit-btn" data-comment-id="{{ comment.id }}" onclick="if(window.editComment){window.editComment({{ comment.id }});}else if(window.GalCommentInteractions&&window.GalCommentInteractions.handleEdit){window.GalCommentInteractions.handleEdit({{ comment.id }});}">编辑</button>
            {% endif %}
            {% if is_admin %}
                <button type="button" class="comment-delete-btn" data-comment-id="{{ comment.id }}" title="删除评论" onclick="window.galDeleteComment({{ comment.id }});">删除</button>
            {% endif %}
        </span>
    </div>
    <div class="comment-body markdown-body">
        {% if comment.parent_id and comment.parent_username %}
            <div class="comment-reply-context">
                <div class="comment-reply-header">回复 <span class="comment-user-link">@{{ comment.parent_username }}</span></div>
                <a href="{{ comment.parent_quote_url|default('#comment-' ~ comment.parent_id) }}" class="comment-reply-quote" data-target-comment-id="{{ comment.parent_id }}">{{ comment.parent_content|default('')|striptags|slice(0, 240) }}</a>
                <div class="comment-reply-divider"></div>
            </div>
        {% endif %}
        <div class="comment-main-content">{{ comment.content_html|raw }}</div>
    </div>
</div>
