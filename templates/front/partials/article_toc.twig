{% if hasToc %}<aside class="article-toc-fixed" id="tocFixed"><div class="article-toc-card" id="tocCard"><div class="article-toc-title article-toc-mobile-toggle" id="tocToggle">目录</div><nav class="article-toc-nav" id="tocNav"><ul>{% for item in tocItems %}<li><a href="#{{ item.id }}" class="toc-level-{{ item.level }}"><span class="toc-indicator"></span><span class="toc-number">{{ item.number }}</span><span class="toc-text">{{ item.text }}</span></a></li>{% endfor %}</ul></nav></div></aside>{% endif %}
