<div class="card" style="margin-bottom: 16px;">
    <div class="card-body" style="padding: 12px 16px;">
        <form method="get" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;">
            <div>
                <label class="form-label" style="margin-bottom:4px;font-size:0.82rem;">报错分类</label>
                <select name="category_id" class="form-input" style="min-width:180px;">
                    <option value="">全部分类</option>
                    {% for category in categories %}
                        <option value="{{ category.id|e('html_attr') }}" {% if category_id == category.id %}selected{% endif %}>{{ category.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="form-label" style="margin-bottom:4px;font-size:0.82rem;">系统分类</label>
                <select name="system_category" class="form-input" style="min-width:180px;">
                    <option value="">全部系统</option>
                    {% for scKey, scLabel in system_category_options %}
                        <option value="{{ scKey|e('html_attr') }}" {% if system_category == scKey %}selected{% endif %}>{{ scLabel }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <button type="submit" class="btn">筛选</button>
                <a href="/error_solutions" class="btn btn-secondary">清除</a>
            </div>
        </form>
    </div>
</div>
