{#
  article_comment.twig —— 单条文章评论（单行内联渲染，结构同 discussion_comment）
  输入（由 article_comments 以 with { comment } 传入）：
    comment         [必填] 同 discussion_comment 的字段集（id/content/content_html/avatar/username/user_id/created_at/parent_*）
    current_user_id [必填] / is_admin [必填] / _is_login [必填] —— 隐式继承，决定 回复/编辑/删除 按钮
  说明：删除按钮调用 window.deleteComment（文章页脚本导出名，与讨论页 galDeleteComment 不同 —— 见 docs/评论系统梳理.md）。
#}
<div class="comment-item" id="comment-{{ comment.id }}" data-comment-content="{{ comment.content|e('html_attr') }}"><div class="comment-author"><span class="comment-author-info">{% if comment.avatar and comment.avatar is not empty %}<img src="/{{ comment.avatar }}" class="comment-author-avatar" alt="">{% else %}<span class="comment-author-avatar fallback">{{ comment.username|slice(0,1) }}</span>{% endif %}<strong><a href="/profile?user_id={{ comment.user_id }}" class="comment-user-link">{{ comment.username }}</a></strong>{% if comment.parent_id and comment.parent_username %}<span class="comment-reply-to">回复 <a href="/profile?user_id={{ comment.parent_user_id|default(0) }}" class="comment-user-link">{{ comment.parent_username }}</a></span>{% endif %}</span><span class="comment-meta-right"><span class="comment-time">{{ comment.created_at|date('Y-m-d H:i') }}</span>{% if _is_login %}<button type="button" class="comment-reply-btn" data-comment-id="{{ comment.id }}" data-comment-username="{{ comment.username }}">回复</button>{% endif %}{% if _is_login and current_user_id == comment.user_id %}<button type="button" class="comment-reply-btn comment-edit-btn" data-comment-id="{{ comment.id }}">编辑</button>{% endif %}{% if is_admin %}<button type="button" class="comment-delete-btn" data-comment-id="{{ comment.id }}" title="删除评论">删除</button>{% endif %}</span></div><div class="comment-body markdown-body">{% if comment.parent_id and comment.parent_username %}<div class="comment-reply-context"><div class="comment-reply-header">回复 <span class="comment-user-link">@{{ comment.parent_username }}</span></div><a href="{{ comment.parent_quote_url|default('#') }}" class="comment-reply-quote">{{ comment.parent_content|default('')|striptags|slice(0,240) }}</a><div class="comment-reply-divider"></div></div>{% endif %}<div class="comment-main-content">{{ comment.content_html|raw }}</div></div></div>
