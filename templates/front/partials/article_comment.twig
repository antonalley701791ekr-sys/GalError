<div class="comment-item" id="comment-{{ comment.id }}" data-comment-content="{{ comment.content|e('html_attr') }}"><div class="comment-author"><span class="comment-author-info">{% if comment.avatar and comment.avatar is not empty %}<img src="/{{ comment.avatar }}" class="comment-author-avatar" alt="">{% else %}<span class="comment-author-avatar fallback">{{ comment.username|slice(0,1) }}</span>{% endif %}<strong><a href="/profile?user_id={{ comment.user_id }}" class="comment-user-link">{{ comment.username }}</a></strong>{% if comment.parent_id and comment.parent_username %}<span class="comment-reply-to">回复 <a href="/profile?user_id={{ comment.parent_user_id|default(0) }}" class="comment-user-link">{{ comment.parent_username }}</a></span>{% endif %}</span><span class="comment-meta-right"><span class="comment-time">{{ comment.created_at|date('Y-m-d H:i') }}</span>{% if _is_login %}<button type="button" class="comment-reply-btn" data-comment-id="{{ comment.id }}" data-comment-username="{{ comment.username }}" onclick="if(window.replyToComment){window.replyToComment({{ comment.id }}, '{{ comment.username|e('js') }}');}">回复</button>{% endif %}{% if _is_login and current_user_id == comment.user_id %}<button type="button" class="comment-reply-btn comment-edit-btn" data-comment-id="{{ comment.id }}" onclick="if(window.editComment){window.editComment({{ comment.id }});}">编辑</button>{% endif %}{% if is_admin %}<button type="button" class="comment-delete-btn" data-comment-id="{{ comment.id }}" title="删除评论" onclick="if(window.deleteComment){window.deleteComment({{ comment.id }});}">删除</button>{% endif %}</span></div><div class="comment-body markdown-body">{% if comment.parent_id and comment.parent_username %}<div class="comment-reply-context"><div class="comment-reply-header">回复 <span class="comment-user-link">@{{ comment.parent_username }}</span></div><a href="{{ comment.parent_quote_url|default('#') }}" class="comment-reply-quote">{{ comment.parent_content|default('')|striptags|slice(0,240) }}</a><div class="comment-reply-divider"></div></div>{% endif %}<div class="comment-main-content">{{ comment.content_html|raw }}</div></div></div>
