<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ game.title }} - {{ _site_name }}</title>
    <link rel="stylesheet" href="/assets/css/style.css?v={{ _assets_ver }}">
    <link rel="stylesheet" href="/assets/css/user.css?v={{ _user_css_ver }}">
    {{ site_head_html|raw }}
</head>
<body class="has-fixed-nav">
{{ header_html|raw }}
{% if from_admin %}
<div class="admin-layout">{{ admin_sidebar_html|raw }}<div class="admin-content"><main class="admin-main">
{% else %}
{{ announcement_html|raw }}<main class="main">
{% endif %}
<div class="container">
<div class="mb-20" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;"><div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;"><a href="/" class="btn btn-secondary btn-sm">返回首页</a>{% if _is_login %}<a href="/submit_game.php?edit_id={{ game.id }}{{ from_admin ? '&from_admin=1' : '' }}" class="btn btn-secondary btn-sm">编辑游戏信息</a>{% endif %}</div></div>
<div class="card"><div class="card-header">游戏信息</div><div class="card-body"><div class="game-detail-layout">{% if game.cover_url %}<button type="button" class="game-detail-cover js-image-viewer-trigger" data-viewer-src="{{ game.cover_url }}" data-viewer-alt="{{ game.title }}" aria-label="查看封面大图"><img src="{{ game.cover_url }}" alt="{{ game.title }}" class="game-detail-cover-img js-adaptive-cover" loading="lazy"></button>{% endif %}<div class="game-detail-info"><h2 class="game-detail-title">{{ game.title }}</h2>{% if game.title_jp %}<p class="game-detail-meta"><strong>日文名：</strong>{{ game.title_jp }}</p>{% endif %}{% if game.romaji %}<p class="game-detail-meta"><strong>罗马音：</strong>{{ game.romaji }}</p>{% endif %}{% if game.aliases %}<p class="game-detail-meta"><strong>别名：</strong>{{ game.aliases }}</p>{% endif %}{% if game.developer %}<p class="game-detail-meta"><strong>开发商：</strong>{{ game.developer }}</p>{% endif %}{% if game.release_date %}<p class="game-detail-meta"><strong>发售日：</strong>{{ game.release_date }}</p>{% endif %}{% if game.platforms %}<p class="game-detail-meta"><strong>平台：</strong>{{ game.platforms }}</p>{% endif %}{% if game.vndb_id %}<p class="game-detail-meta"><strong>VNDB：</strong><a href="https://vndb.org/{{ game.vndb_id }}" target="_blank">{{ game.vndb_id }}</a></p>{% endif %}<p class="game-detail-meta"><strong>收录时间：</strong>{{ game.created_date }}</p>{% if from_admin and game.status != 'approved' %}<p class="game-detail-meta"><strong>审核状态：</strong><span class="status status-{{ game.status }}">{{ game.status == 'pending' ? '待审核' : '已拒绝' }}</span></p>{% endif %}{% if from_admin and game.status == 'rejected' and game.reject_reason %}<div class="info-block info-block-danger review-reject-reason" style="margin:10px 0 6px;"><strong>驳回原因：</strong><div class="review-reject-reason-content">{{ game.reject_reason|nl2br }}</div></div>{% endif %}{% if game.submitter_name %}<p class="game-detail-meta"><strong>提交者：</strong><span class="js-user-card" data-user-id="{{ game.user_id }}" data-username="{{ game.submitter_name }}"><a href="/profile?user_id={{ game.user_id }}" class="detail-author-link">{{ game.submitter_name }}</a></span></p>{% endif %}<p class="game-detail-meta view-count-detail" title="浏览量">登录浏览：<span id="view-count-user">{{ game.view_user }}</span> | 访客浏览：<span id="view-count-guest">{{ game.view_guest }}</span></p></div></div></div></div>
{% if game_revisions is not empty %}<div class="card section-gap"><div class="card-header">游戏信息修改记录</div><div class="card-body"><div class="revision-history">{% for rev in game_revisions %}<div class="revision-item"><div class="revision-meta"><span>修改者：{{ rev.submitter_name ?: '匿名用户' }}</span><span>时间：{{ rev.created_text }}</span></div>{% for d in rev.diffs %}<div class="revision-diff"><strong>{{ d.label }}：</strong>{% if d.mode == 'added' %}<div class="diff-added">{{ d.new|nl2br }}</div>{% elseif d.mode == 'removed' %}<div class="diff-removed">{{ d.old|nl2br }}</div>{% else %}<div class="diff-removed">{{ d.old|nl2br }}</div><div class="diff-added">{{ d.new|nl2br }}</div>{% endif %}</div>{% endfor %}</div>{% endfor %}</div></div></div>{% endif %}
<div class="section-gap"><h2 class="card-header" style="display:flex;justify-content:space-between;align-items:center;">报错解决方案{% if errors|length > 5 %}<span style="font-size:0.85rem;font-weight:400;color:var(--text-muted);">共 {{ errors|length }} 条</span>{% endif %}</h2>{% if errors is not empty %}<div class="card-body error-brief-list">{% for error in errors|slice(0,5) %}<a class="error-brief-card" href="{{ error.url }}"><div class="error-brief-main"><h3 class="error-brief-title">{{ error.title }}</h3><p class="error-brief-summary">{{ error.solution_short ?: '暂无解决方案' }}</p></div><div class="error-brief-meta"><span class="article-tag-sm">{{ error.category_name }}</span><span>{{ error.created_date }}</span><span class="view-count-inline" title="浏览量">{{ error.view_count }}</span><span class="comment-count-inline" title="评论数">{{ error.comment_count }}</span></div></a>{% endfor %}</div>{% else %}<div class="card-body text-center empty-state"><p>该游戏暂无报错解决方案</p><p><a href="/submit?game_id={{ game.id }}" class="btn">提交第一个报错解决方案</a></p></div>{% endif %}</div>
<div class="section-gap text-center"><a href="/submit?game_id={{ game.id }}" class="btn">为该游戏提交报错</a>{% if from_admin %}<a href="/admin/games.php" class="btn btn-secondary" style="margin-left: 10px;">返回列表</a>{% else %}<a href="/" class="btn btn-secondary" style="margin-left: 10px;">返回首页</a>{% endif %}</div>
</div>
{% if from_admin %}</main></div></div>{{ admin_footer_scripts_html|raw }}{% else %}</main>{% endif %}
{% if not from_admin %}
{{ footer_html|raw }}
{% endif %}
<div id="view-counter-config" data-type="game" data-id="{{ game.id }}" data-csrf="{{ csrf }}" style="display:none;"></div>
<script src="/assets/js/view-counter.js"></script>
<script src="/assets/js/adaptive-cover.js?v={{ _assets_ver }}"></script>
<script src="/assets/js/user-card.js?v={{ _user_card_js_ver }}"></script>
</body>
</html>