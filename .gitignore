# =========================
# Git ignore for PHP website
# =========================

# --- Local runtime / sensitive local files ---
.user.ini
/.user.ini

# --- Environment / secrets ---
.env
.env.*
!.env.example
/includes/config.php
/config.php

# --- OS / Editor ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo

# --- Logs / temp / cache ---
*.log
*.pid
*.tmp
*.temp
cache/
tmp/
sessions/

# --- Uploads / runtime data ---
data/

# --- Archives / backups / dumps ---
*.sql
*.sqlite
*.sqlite3
*.bak
*.backup
*.old
*.zip
*.7z
*.rar

# --- Common build artifacts ---
node_modules/
dist/
build/

# --- Windows reserved names (defensive) ---
nul
NUL
